  <graph edgedefault="undirected">
    <node id="Newspeak Dictionary">
      <data key="d0">Newspeak Dictionary</data>
      <data key="d1">artifact</data>
      <data key="d2">The Newspeak Dictionary contains definitions and information about the language as used by the Party.&lt;SEP&gt;The Newspeak Dictionary is a tool used to transform traditional words into new comprehensive terms for the purpose of controlling thought.</data>
      <data key="d3">chunk-6a5e67b8589ccc49c8c351f04a3fb597&lt;SEP&gt;chunk-92717df9c2dcca52c329b543c7e1f93a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752386</data>
    </node>
    <node id="OLDTHINK">
      <data key="d0">OLDTHINK</data>
      <data key="d1">concept</data>
      <data key="d2">OLDTHINK is a term in Newspeak that represents concepts like wickedness and decadence, which are destroyed by the extension of its meaning.&lt;SEP&gt;The concept OLDTHINK has been extended to include whole batteries of words that could now be scrapped.</data>
      <data key="d3">chunk-92717df9c2dcca52c329b543c7e1f93a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752386</data>
    </node>
    <node id="FREE">
      <data key="d0">FREE</data>
      <data key="d1">concept</data>
      <data key="d2">The word FREE has had heretical meanings purged out to maintain orthodoxy within the Party.</data>
      <data key="d3">chunk-92717df9c2dcca52c329b543c7e1f93a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752387</data>
    </node>
    <node id="HONOUR">
      <data key="d0">HONOUR</data>
      <data key="d1">concept</data>
      <data key="d2">The concept of HONOUR, along with other terms like JUSTICE and MORALITY, have ceased to exist in Newspeak.</data>
      <data key="d3">chunk-92717df9c2dcca52c329b543c7e1f93a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752387</data>
    </node>
    <node id="JUSTICE">
      <data key="d0">JUSTICE</data>
      <data key="d1">concept</data>
      <data key="d2">Concepts like JUSTICE have been purged from the language of Newspeak.</data>
      <data key="d3">chunk-92717df9c2dcca52c329b543c7e1f93a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752387</data>
    </node>
    <node id="MORALITY">
      <data key="d0">MORALITY</data>
      <data key="d1">concept</data>
      <data key="d2">The concept of MORALITY has been abolished through the use of comprehensive terms in Newspeak.</data>
      <data key="d3">chunk-92717df9c2dcca52c329b543c7e1f93a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752387</data>
    </node>
    <node id="INTERNATIONALISM">
      <data key="d0">INTERNATIONALISM</data>
      <data key="d1">concept</data>
      <data key="d2">The term INTERNATIONALISM is one of several concepts that have been purged from the language.</data>
      <data key="d3">chunk-92717df9c2dcca52c329b543c7e1f93a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752388</data>
    </node>
    <node id="DEMOCRACY">
      <data key="d0">DEMOCRACY</data>
      <data key="d1">concept</data>
      <data key="d2">DEMOCRACY has ceased to exist as a concept in Newspeak, covered by other comprehensive terms.</data>
      <data key="d3">chunk-92717df9c2dcca52c329b543c7e1f93a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752388</data>
    </node>
    <node id="SCIENCE">
      <data key="d0">SCIENCE</data>
      <data key="d1">concept</data>
      <data key="d2">The term SCIENCE is another example of a concept that has been purged from the language of Newspeak.</data>
      <data key="d3">chunk-92717df9c2dcca52c329b543c7e1f93a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752388</data>
    </node>
    <node id="RELIGION">
      <data key="d0">RELIGION</data>
      <data key="d1">concept</data>
      <data key="d2">RELIGION as a concept no longer exists in Newspeak, covered by other comprehensive terms.</data>
      <data key="d3">chunk-92717df9c2dcca52c329b543c7e1f93a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752388</data>
    </node>
    <node id="CRIMETHINK">
      <data key="d0">CRIMETHINK</data>
      <data key="d1">concept</data>
      <data key="d2">CRIMETHINK is a B Word formed as "thoughtcrime," used to describe criminal thoughts or beliefs.&lt;SEP&gt;CRIMETHINK is a term that groups concepts of liberty and equality, used to abolish such ideas.&lt;SEP&gt;CRIMETHINK is a Newspeak term used to label thoughts that are considered criminal or heretical.</data>
      <data key="d3">chunk-491b3d4aaf8461a08befc0aab83f4bba&lt;SEP&gt;chunk-92717df9c2dcca52c329b543c7e1f93a&lt;SEP&gt;chunk-877c954ec93bb835f0176da84c3b5889</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752389</data>
    </node>
    <node id="SEXCRIME">
      <data key="d0">SEXCRIME</data>
      <data key="d1">concept</data>
      <data key="d2">SEXCRIME is a Newspeak term used for sexual immorality, regulating the sexual life of Party members.&lt;SEP&gt;SEXCRIME refers to sexual misdeeds that are considered immoral or perversions under Newspeak.</data>
      <data key="d3">chunk-92717df9c2dcca52c329b543c7e1f93a&lt;SEP&gt;chunk-a0a7c4405603e7bd6c621e4885a85ebc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752389</data>
    </node>
    <node id="GOODSEX">
      <data key="d0">GOODSEX</data>
      <data key="d1">concept</data>
      <data key="d2">GOODSEX is another Newspeak term defining permissible sexual conduct in a generalized way.&lt;SEP&gt;GOODSEX represents normal intercourse between man and wife for the purpose of begetting children without physical pleasure on the part of the woman.</data>
      <data key="d3">chunk-92717df9c2dcca52c329b543c7e1f93a&lt;SEP&gt;chunk-a0a7c4405603e7bd6c621e4885a85ebc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752389</data>
    </node>
    <node id="Newspeak Words">
      <data key="d0">Newspeak Words</data>
      <data key="d1">artifact</data>
      <data key="d2">Newspeak words are terms used to transform or destroy traditional meanings, often grouping multiple concepts into one comprehensive term.</data>
      <data key="d3">chunk-92717df9c2dcca52c329b543c7e1f93a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752389</data>
    </node>
    <node id="Prestige">
      <data key="d0">Prestige</data>
      <data key="d1">concept</data>
      <data key="d2">Prestige refers to the social status or honor that influenced decisions regarding historical figures.</data>
      <data key="d3">chunk-3ac0f368d161e0b4a92e4feca495cd11</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752389</data>
    </node>
    <node id="Certain Historical Figures">
      <data key="d0">Certain Historical Figures</data>
      <data key="d1">person</data>
      <data key="d2">Historical figures whose memory was preserved and aligned with Ingsoc's philosophy.</data>
      <data key="d3">chunk-3ac0f368d161e0b4a92e4feca495cd11</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752389</data>
    </node>
    <node id="Ingsoc">
      <data key="d0">Ingsoc</data>
      <data key="d1">organization</data>
      <data key="d2">Ingsoc, or English Socialism, is the ideology and party that governs Oceania in the story.&lt;SEP&gt;Ingsoc refers to the principles of Newspeak, indicating a political ideology or organization.&lt;SEP&gt;INGSOC stands for English Socialism and represents the official ideology in Newspeak society.&lt;SEP&gt;Ingsoc stands for English Socialism and represents the totalitarian ideology in the dystopian society.&lt;SEP&gt;Ingsoc is an organization whose ideas are inimical to Newspeak and could only be vaguely entertained or condemned without clear definition.&lt;SEP&gt;Ingsoc is the Party's ideology or official belief system in Orwell's dystopian society.</data>
      <data key="d3">chunk-491b3d4aaf8461a08befc0aab83f4bba&lt;SEP&gt;chunk-d6180f0140c592fb4bd1c07a384d5423&lt;SEP&gt;chunk-72158fb48dfe5cb1a9c716f76eae16d9&lt;SEP&gt;chunk-6a5e67b8589ccc49c8c351f04a3fb597&lt;SEP&gt;chunk-3ac0f368d161e0b4a92e4feca495cd11&lt;SEP&gt;chunk-e344b38beed08083660fea5486c5abe3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752390</data>
    </node>
    <node id="Shakespeare">
      <data key="d0">Shakespeare</data>
      <data key="d1">person</data>
      <data key="d2">William Shakespeare, an English playwright whose works were subject to translation.</data>
      <data key="d3">chunk-3ac0f368d161e0b4a92e4feca495cd11</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752390</data>
    </node>
    <node id="Milton">
      <data key="d0">Milton</data>
      <data key="d1">person</data>
      <data key="d2">John Milton, a poet and writer known for his literary contributions.</data>
      <data key="d3">chunk-3ac0f368d161e0b4a92e4feca495cd11</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752390</data>
    </node>
    <node id="Swift">
      <data key="d0">Swift</data>
      <data key="d1">person</data>
      <data key="d2">Jonathan Swift, author of "Gulliver's Travels," among other works.</data>
      <data key="d3">chunk-3ac0f368d161e0b4a92e4feca495cd11</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752390</data>
    </node>
    <node id="Byron">
      <data key="d0">Byron</data>
      <data key="d1">person</data>
      <data key="d2">Lord Byron, an English Romantic poet whose writings were part of the translation process.</data>
      <data key="d3">chunk-3ac0f368d161e0b4a92e4feca495cd11</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752391</data>
    </node>
    <node id="Dickens">
      <data key="d0">Dickens</data>
      <data key="d1">person</data>
      <data key="d2">Charles Dickens, a prominent novelist with literary works needing translation.</data>
      <data key="d3">chunk-3ac0f368d161e0b4a92e4feca495cd11</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752391</data>
    </node>
    <node id="Technical Manuals">
      <data key="d0">Technical Manuals</data>
      <data key="d1">artifact</data>
      <data key="d2">Technical manuals and similar utilitarian literature that required translation or adaptation.</data>
      <data key="d3">chunk-3ac0f368d161e0b4a92e4feca495cd11</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752391</data>
    </node>
    <node id="Sexual Immorality">
      <data key="d0">Sexual Immorality</data>
      <data key="d1">concept</data>
      <data key="d2">Sexual Immorality covers all forms of sexual misconduct, including fornication, adultery, homosexuality, and other perversions.</data>
      <data key="d3">chunk-a0a7c4405603e7bd6c621e4885a85ebc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752392</data>
    </node>
    <node id="Fornication">
      <data key="d0">Fornication</data>
      <data key="d1">event</data>
      <data key="d2">Fornication is an act considered a form of SEXCRIME under Newspeak.</data>
      <data key="d3">chunk-a0a7c4405603e7bd6c621e4885a85ebc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752392</data>
    </node>
    <node id="Newspeak">
      <data key="d0">Newspeak</data>
      <data key="d1">concept</data>
      <data key="d2">Newspeak is a constructed language originally devised as part of George Orwell's dystopian novel, *1984*. This language was designed to limit the range and freedom of thought by Ingsoc (the ruling party in Oceania) through its controlled vocabulary. The primary goal was to diminish the ability to think about or express concepts outside the ideological framework imposed by the Party. Newspeak aimed to restrict vocabulary and expression, thereby suppressing certain ideas—especially those related to political equality—and limiting the range of thought. It is described as an official language in Oceania, characterized by its controlled vocabulary and emphasis on euphony and political correctness, which were intended to reinforce the regime's control over individuals' thoughts and behaviors.</data>
      <data key="d3">chunk-dc8d92b2ecc0fa26ebda9e2c6d77c94d&lt;SEP&gt;chunk-56af4c612173c531ce5df3d6ad3e4204&lt;SEP&gt;chunk-d6180f0140c592fb4bd1c07a384d5423&lt;SEP&gt;chunk-877c954ec93bb835f0176da84c3b5889&lt;SEP&gt;chunk-f3461be011bed873ca130b8edc1a052b&lt;SEP&gt;chunk-6a5e67b8589ccc49c8c351f04a3fb597&lt;SEP&gt;chunk-3ac0f368d161e0b4a92e4feca495cd11&lt;SEP&gt;chunk-e344b38beed08083660fea5486c5abe3&lt;SEP&gt;chunk-a0a7c4405603e7bd6c621e4885a85ebc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752392</data>
    </node>
    <node id="Adultery">
      <data key="d0">Adultery</data>
      <data key="d1">event</data>
      <data key="d2">Adultery is also classified as a form of SEXCRIME in the context of Newspeak.</data>
      <data key="d3">chunk-a0a7c4405603e7bd6c621e4885a85ebc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752392</data>
    </node>
    <node id="Homosexuality">
      <data key="d0">Homosexuality</data>
      <data key="d1">event</data>
      <data key="d2">Homosexuality, categorized by Newspeak as a type of sexual immorality.</data>
      <data key="d3">chunk-a0a7c4405603e7bd6c621e4885a85ebc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752393</data>
    </node>
    <node id="Death Penalty">
      <data key="d0">Death Penalty</data>
      <data key="d1">concept</data>
      <data key="d2">All acts considered SEXCRIME are punishable by death under the principles of Newspeak.</data>
      <data key="d3">chunk-a0a7c4405603e7bd6c621e4885a85ebc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752393</data>
    </node>
    <node id="C vocabulary">
      <data key="d0">C vocabulary</data>
      <data key="d1">category</data>
      <data key="d2">C vocabulary is part of the language system in Oceania, focusing on scientific and technical terms.</data>
      <data key="d3">chunk-a0a7c4405603e7bd6c621e4885a85ebc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752393</data>
    </node>
    <node id="B vocabulary">
      <data key="d0">B vocabulary</data>
      <data key="d1">category</data>
      <data key="d2">B vocabulary is another component of the Newspeak language, designed to have ideological significance.&lt;SEP&gt;B vocabulary refers to a form of Newspeak where political terms are shortened for easier pronunciation.</data>
      <data key="d3">chunk-a0a7c4405603e7bd6c621e4885a85ebc&lt;SEP&gt;chunk-cf837caf239da2f8d9dc1f8eda04c678</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752393</data>
    </node>
    <node id="JOYCAMP">
      <data key="d0">JOYCAMP</data>
      <data key="d1">artifact</data>
      <data key="d2">JOYCAMP refers to forced-labour camps in Newspeak and is a euphemism for such institutions.</data>
      <data key="d3">chunk-a0a7c4405603e7bd6c621e4885a85ebc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752393</data>
    </node>
    <node id="MINIPAX">
      <data key="d0">MINIPAX</data>
      <data key="d1">organization</data>
      <data key="d2">MINIPAX stands for the Ministry of Peace, which paradoxically corresponds to the Ministry of War under Newspeak.</data>
      <data key="d3">chunk-a0a7c4405603e7bd6c621e4885a85ebc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752394</data>
    </node>
    <node id="Oceanic Society">
      <data key="d0">Oceanic Society</data>
      <data key="d1">society</data>
      <data key="d2">Oceanic Society is the totalitarian society where Newspeak and its language restrictions are enforced.</data>
      <data key="d3">chunk-a0a7c4405603e7bd6c621e4885a85ebc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752394</data>
    </node>
    <node id="Prolefeed">
      <data key="d0">Prolefeed</data>
      <data key="d1">concept</data>
      <data key="d2">Prolefeed refers to the entertainment and false news provided by the Party to the masses in Oceania.&lt;SEP&gt;Prolefeed is a Newspeak term likely referring to propaganda aimed at the lower classes (proles).</data>
      <data key="d3">chunk-a0a7c4405603e7bd6c621e4885a85ebc&lt;SEP&gt;chunk-d6180f0140c592fb4bd1c07a384d5423</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752394</data>
    </node>
    <node id="Ministry of Truth">
      <data key="d0">Ministry of Truth</data>
      <data key="d1">organization</data>
      <data key="d2">The Ministry of Truth is an organization within the fictional government, responsible for propaganda and control of information.&lt;SEP&gt;The Ministry of Truth is an organization responsible for news control and propaganda.</data>
      <data key="d3">chunk-d6180f0140c592fb4bd1c07a384d5423&lt;SEP&gt;chunk-cf837caf239da2f8d9dc1f8eda04c678</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752394</data>
    </node>
    <node id="Winston Smith">
      <data key="d0">Winston Smith</data>
      <data key="d1">person</data>
      <data key="d2">Winston Smith works in the Records Department at the Ministry of Truth.</data>
      <data key="d3">chunk-cf837caf239da2f8d9dc1f8eda04c678</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752394</data>
    </node>
    <node id="Records Department">
      <data key="d0">Records Department</data>
      <data key="d1">department</data>
      <data key="d2">The Records Department is part of the Ministry of Truth, where Winston Smith works.</data>
      <data key="d3">chunk-cf837caf239da2f8d9dc1f8eda04c678</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752395</data>
    </node>
    <node id="Fiction Department">
      <data key="d0">Fiction Department</data>
      <data key="d1">department</data>
      <data key="d2">The Fiction Department is a part of the Ministry of Truth.</data>
      <data key="d3">chunk-cf837caf239da2f8d9dc1f8eda04c678</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752395</data>
    </node>
    <node id="Teleprogrammes Department">
      <data key="d0">Teleprogrammes Department</data>
      <data key="d1">department</data>
      <data key="d2">The Teleprogrammes Department is another department within the Ministry of Truth.</data>
      <data key="d3">chunk-cf837caf239da2f8d9dc1f8eda04c678</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752395</data>
    </node>
    <node id="NAZI">
      <data key="d0">NAZI</data>
      <data key="d1">concept</data>
      <data key="d2">NAZI represents a term used in Newspeak to abbreviate National Socialist German Workers' Party.</data>
      <data key="d3">chunk-cf837caf239da2f8d9dc1f8eda04c678</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752395</data>
    </node>
    <node id="GESTAPO">
      <data key="d0">GESTAPO</data>
      <data key="d1">concept</data>
      <data key="d2">GESTAPO stands for Geheime Staatspolizei, representing the secret police in Nazi Germany.</data>
      <data key="d3">chunk-cf837caf239da2f8d9dc1f8eda04c678</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752395</data>
    </node>
    <node id="COMINTERN">
      <data key="d0">COMINTERN</data>
      <data key="d1">concept</data>
      <data key="d2">COMINTERN is an abbreviation of Communist International, a political organization.</data>
      <data key="d3">chunk-cf837caf239da2f8d9dc1f8eda04c678</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752396</data>
    </node>
    <node id="AGITPROP">
      <data key="d0">AGITPROP</data>
      <data key="d1">concept</data>
      <data key="d2">AGITPROP is an abbreviation for agitation and propaganda, a term used in Soviet politics.</data>
      <data key="d3">chunk-cf837caf239da2f8d9dc1f8eda04c678</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752396</data>
    </node>
    <node id="MINTRU">
      <data key="d0">MINTRU</data>
      <data key="d1">abbreviation</data>
      <data key="d2">MINTRU is an abbreviated form of MINISTRY OF TRUTH in Newspeak, designed to be easily pronounceable.</data>
      <data key="d3">chunk-cf837caf239da2f8d9dc1f8eda04c678</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752396</data>
    </node>
    <node id="MINISTRY OF TRUTH">
      <data key="d0">MINISTRY OF TRUTH</data>
      <data key="d1">organization</data>
      <data key="d2">The Ministry of Truth is an organization within the fictional government, responsible for propaganda and control of information.</data>
      <data key="d3">chunk-cf837caf239da2f8d9dc1f8eda04c678</data>
      <data key="d4">unknown_source</data>
