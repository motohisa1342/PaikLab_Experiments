    <node id="-S,-ES">
      <data key="d0">-S,-ES</data>
      <data key="d3">chunk-563c6c743b686961b6884d542125ac31</data>
      <data key="d2">-ED endings are used for both preterite and past participle forms of verbs, while -S or -ES can form plurals.&lt;SEP&gt;-S or -ES can be used as plural suffixes for words like MANS, while -ED is used for past tense and past participle.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752428</data>
    </node>
