      <data key="d4">unknown_source</data>
      <data key="d5">1781752399</data>
    </node>
    <node id="UNCOLD">
      <data key="d0">UNCOLD</data>
      <data key="d1">concept</data>
      <data key="d2">UNCOLD is a Newspeak word that means 'warm' by negating the meaning of COLD with UN- prefix.&lt;SEP&gt;UNCOLD means 'warm' in Newspeak.</data>
      <data key="d3">chunk-563c6c743b686961b6884d542125ac31&lt;SEP&gt;chunk-56af4c612173c531ce5df3d6ad3e4204</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752399</data>
    </node>
    <node id="PLUSCOLD">
      <data key="d0">PLUSCOLD</data>
      <data key="d1">concept</data>
      <data key="d2">PLUSCOLD strengthens the meaning of COLD to mean 'very cold' with PLUS- prefix in Newspeak.&lt;SEP&gt;PLUSCOLD means 'very cold' in Newspeak.</data>
      <data key="d3">chunk-563c6c743b686961b6884d542125ac31&lt;SEP&gt;chunk-56af4c612173c531ce5df3d6ad3e4204</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752399</data>
    </node>
    <node id="DOUBLEPLUSCOLD">
      <data key="d0">DOUBLEPLUSCOLD</data>
      <data key="d1">concept</data>
      <data key="d2">DOUBLEPLUSCOLD further intensifies the meaning of COLD to mean 'superlatively cold' with DOUBLEPLUS- prefix in Newspeak.&lt;SEP&gt;DOUBLEPLUSCOLD means 'superlatively cold' in Newspeak.</data>
      <data key="d3">chunk-563c6c743b686961b6884d542125ac31&lt;SEP&gt;chunk-56af4c612173c531ce5df3d6ad3e4204</data>
