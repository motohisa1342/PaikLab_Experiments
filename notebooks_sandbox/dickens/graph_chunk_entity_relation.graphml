      <data key="d0">The Times</data>
      <data key="d1">organization</data>
      <data key="d2">The Times is a fictitious newspaper that publishes articles in Newspeak.</data>
      <data key="d3">chunk-6a5e67b8589ccc49c8c351f04a3fb597</data>
      <data key="d4">unknown_source</data>
