    <edge source="-ED" target="-S,-ES">
      <data key="d6">2.0</data>
      <data key="d7">-ED endings are used for both preterite and past participle forms of verbs, while -S or -ES can form plurals.&lt;SEP&gt;-S or -ES can be used as plural suffixes for words like MANS, while -ED is used for past tense and past participle.</data>
      <data key="d8">plural formation,verb inflection</data>
      <data key="d9">chunk-563c6c743b686961b6884d542125ac31</data>
      <data key="d10">unknown_source</data>
      <data key="d11">1781752428</data>
    </edge>
    <edge source="-ED" target="SWAM">
      <data key="d6">1.0</data>
      <data key="d7">SWAM's past tense and participle form is STEALED.</data>
