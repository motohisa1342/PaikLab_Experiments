    </node>
    <node id="Oldspeak">
      <data key="d0">Oldspeak</data>
      <data key="d1">concept</data>
      <data key="d2">Oldspeak, or Standard English, is the original language that Newspeak aims to replace.&lt;SEP&gt;Oldspeak is an earlier language or dialect compared to Newscpake and can be translated into some B vocabulary words.&lt;SEP&gt;Oldspeak is the previous language which contains words and concepts not present in Newspeak but will eventually be superseded.&lt;SEP&gt;Oldspeak was a language that had been superseded by Newspeak, serving as the last link with the past.</data>
      <data key="d3">chunk-6a5e67b8589ccc49c8c351f04a3fb597&lt;SEP&gt;chunk-72158fb48dfe5cb1a9c716f76eae16d9&lt;SEP&gt;chunk-877c954ec93bb835f0176da84c3b5889&lt;SEP&gt;chunk-e344b38beed08083660fea5486c5abe3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752398</data>
    </node>
    <node id="Party Members">
      <data key="d0">Party Members</data>
      <data key="d1">person</data>
      <data key="d2">Party Members are individuals who adhere to and support Ingsoc in Oceania.</data>
      <data key="d3">chunk-6a5e67b8589ccc49c8c351f04a3fb597</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752398</data>
    </node>
    <node id="Newspeak Vocabulary">
      <data key="d0">Newspeak Vocabulary</data>
      <data key="d1">concept</data>
      <data key="d2">The vocabulary of Newspeak, designed to limit heretical thoughts by excluding certain words and meanings.</data>
      <data key="d3">chunk-6a5e67b8589ccc49c8c351f04a3fb597</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1781752398</data>
    </node>
