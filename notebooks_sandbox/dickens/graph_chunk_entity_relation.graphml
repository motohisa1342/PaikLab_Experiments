    </edge>
    <edge source="MINIPAX" target="minipax">
      <data key="d6">1.0</data>
      <data key="d7">MINIPAX is an artifact derived from MINIPEACEFUL, representing slightly peaceful state or feeling and implies MINIPAX.</data>
